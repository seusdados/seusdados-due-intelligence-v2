# === OBRIGATÓRIAS ===

# Conexão com banco PostgreSQL
DATABASE_URL=

# Segurança
JWT_SECRET=

# Porta do servidor (padrão: 3000)
PORT=

# App ID (usado no JWT)
VITE_APP_ID=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# DigitalOcean Spaces (Storage de arquivos)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=
DO_SPACES_CDN_ENDPOINT=

# URLs públicas
PUBLIC_APP_URL=
FRONTEND_URL=

# Recursos opcionais
ENABLE_REVIEW_CRON=true
ENABLE_ASSESSMENT_EMAIL_NOTIFICATIONS=true
MEUDPO_SLA_SCHEDULER_AUTOSTART=true
