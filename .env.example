# === OBRIGATÓRIAS ===

# Conexão com banco PostgreSQL
DATABASE_URL=

# Segurança
JWT_SECRET=

# Porta do servidor (padrão: 3000)
PORT=

# App ID (usado no JWT)
VITE_APP_ID=

# === OPCIONAIS ===

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Forge AI API (legado - não mais utilizado para storage)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=

# DigitalOcean Spaces (Storage de arquivos)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=
DO_SPACES_ENDPOINT=
DO_SPACES_BUCKET=
DO_SPACES_CDN_ENDPOINT=

# URLs públicas
PUBLIC_APP_URL=
FRONTEND_URL=
# VITE_APP_URL=http://localhost:5173

# Supabase (para storage/GED)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# AWS S3 (substituído por DigitalOcean Spaces)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# Recursos opcionais
ENABLE_REVIEW_CRON=true
ENABLE_ASSESSMENT_EMAIL_NOTIFICATIONS=true
MEUDPO_SLA_SCHEDULER_AUTOSTART=true
